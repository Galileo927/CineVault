{
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080,
      "https": false
    }
  ],
  "app": {
    "number_of_threads": 0,
    "enable_session": false,
    "log": {
      "log_path": "./logs",
      "logfile_base_name": "cinevault",
      "log_size_limit": 100000000,
      "log_level": "INFO"
    }
  },
  "custom_config": {
    "database_path": "./data/cinevault.sqlite3",
    "media_roots": [
      "./media"
    ],
    "ffprobe_path": "ffprobe",
    "ffmpeg_path": "ffmpeg",
    "poster_cache_path": "./data/posters",
    "transcode_cache_path": "./data/transcode"
  }
}
